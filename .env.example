# Example environment configuration
# Update values as needed and rename to ".env" for local development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@db:5432/wealthmachine

# Local HS256 JWT settings. Production must replace every placeholder, protect
# and rotate the secret, and bind tokens to the deployed issuer and audience.
JWT_SECRET_KEY=change-me
JWT_ISSUER=wealthmachine-local
JWT_AUDIENCE=wealthmachine-api
ALLOW_DEMO_AUTH=false
AUTO_CREATE_SCHEMA=false
ADMIN_AUDIT_LEDGER_PATH=
ALLOW_SCHEMA_DROP=false
DATABASE_DROP_CONFIRMATION=
ALLOWED_ORIGINS=
ALLOWED_HOSTS=

# Constitutional Control Plane. Authority IDs must match verified JWT subjects.
# Configure at least two distinct humans (the root also counts as a human).
CONTROL_ROOT_AUTHORITY_ID=
CONTROL_HUMAN_AUTHORITY_IDS=
CONTROL_STATE_DB_PATH=var/control/control.db
CONTROL_EVIDENCE_LEDGER_PATH=var/control/evidence.jsonl
CONTROL_POLICY_VERSION=v1
CONTROL_MAX_GRANT_TTL_HOURS=24
CONTROL_MAX_APPROVAL_TTL_MINUTES=60

# Deployment environment (development or production)
ENVIRONMENT=development

# Port for Prometheus metrics server
METRICS_PORT=9090

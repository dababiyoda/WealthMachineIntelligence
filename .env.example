# UAT governed preview release-candidate configuration.
# Never commit real values. Generate independent secrets for every environment.

ENVIRONMENT=production
DATABASE_URL=sqlite:////data/uat-preview.db
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Production disables built-in demo identities. Supply one operator through
# deployment secrets. Use a dedicated enterprise identity provider later.
UAT_ALLOW_DEMO_USERS=false
UAT_OPERATOR_ID=operator-primary
UAT_OPERATOR_USERNAME=replace-me
UAT_OPERATOR_PASSWORD=replace-me-with-a-secret

# Explicitly opt in only for a bounded preview. This creates R0/R1 analysis and
# sandbox grants; it never grants external execution.
UAT_BOOTSTRAP_PREVIEW=false

UAT_TRUSTED_HOSTS=localhost,127.0.0.1
UAT_ALLOWED_ORIGINS=
UAT_ENABLE_DOCS=false
UAT_RATE_LIMIT_CALLS=180
UAT_RATE_LIMIT_PERIOD_SECONDS=60

# Required in production before the DALEOBANKS intake bridge will accept data.
WEALTHMACHINE_INTAKE_TOKEN=replace-with-an-independent-random-secret
